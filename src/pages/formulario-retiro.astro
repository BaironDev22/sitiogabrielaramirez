---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Formulario de Retiro - SexoloGabi" description="Solicita tu invitación para el retiro de inteligencia sexual consciente">
	
	<!-- Background decorativo global -->
	<div class="fixed inset-0 pointer-events-none z-0 overflow-hidden">
		<div class="absolute top-0 right-0 w-100 h-100 bg-coral-50 rounded-full blur-[120px] translate-x-1/3 -translate-y-1/3"></div>
		<div class="absolute bottom-1/4 left-0 w-125 h-125 bg-secondary rounded-full blur-[140px] -translate-x-1/2"></div>
	</div>

	<div class="relative z-10 min-h-screen">
		<section class="min-h-screen flex items-center py-24 px-6 md:px-12 lg:px-20">
			<div class="max-w-7xl mx-auto w-full grid lg:grid-cols-2 gap-0 lg:gap-0 items-center min-h-[80vh]">
				
				<!-- Formulario - Lado Izquierdo -->
				<div class="order-1 lg:order-1 bg-white/95 backdrop-blur-sm p-12 lg:p-16 h-full flex flex-col justify-center shadow-xl">
					<!-- Logo/Header -->
					<div class="mb-8">
						<div class="flex items-center gap-2 mb-6">
							<svg class="w-6 h-6 text-accent" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
							</svg>
							<span class="text-dark font-semibold text-lg">SexoloGabi</span>
						</div>

						<span class="inline-block text-accent font-medium tracking-widest text-xs uppercase mb-4">
							LISTA DE ESPERA VIP
						</span>

						<h1 class="font-serif text-4xl lg:text-5xl text-dark mb-4 leading-tight">
							Solicitar Invitación
						</h1>

						<p class="text-gray-600 text-base leading-relaxed mb-8 max-w-md">
							Dada la naturaleza íntima y personalizada de nuestros retiros y programas, el acceso es por aplicación. Cuéntanos sobre ti para comenzar tu viaje.
						</p>
					</div>

					<!-- Formulario -->
					<form class="space-y-6">
						<!-- Nombre Completo -->
						<div>
							<label for="nombre" class="block text-dark font-medium mb-3 text-sm uppercase tracking-wide">
								NOMBRE COMPLETO
							</label>
							<input 
								type="text" 
								id="nombre"
								name="nombre"
								placeholder="Tu nombre completo"
								class="w-full px-4 py-4 border border-gray-300 rounded-none focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all duration-300 text-dark placeholder-gray-400"
								required
							>
						</div>

						<!-- Correo Electrónico -->
						<div>
							<label for="email" class="block text-dark font-medium mb-3 text-sm uppercase tracking-wide">
								CORREO ELECTRÓNICO
							</label>
							<input 
								type="email" 
								id="email"
								name="email"
								placeholder="tu@correo.com"
								class="w-full px-4 py-4 border border-gray-300 rounded-none focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all duration-300 text-dark placeholder-gray-400"
								required
							>
						</div>

						<!-- Teléfono -->
						<div>
							<label for="telefono" class="block text-dark font-medium mb-3 text-sm uppercase tracking-wide">
								TELÉFONO
							</label>
							<input 
								type="tel" 
								id="telefono"
								name="telefono"
								placeholder="+56 9 5835 0003"
								class="w-full px-4 py-4 border border-gray-300 rounded-none focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all duration-300 text-dark placeholder-gray-400"
								required
							>
						</div>

						<!-- Mensaje -->
						<div>
							<label for="mensaje" class="block text-dark font-medium mb-3 text-sm uppercase tracking-wide">
								CUÉNTANOS SOBRE TU INTERÉS EN EL RETIRO
							</label>
							<textarea 
								id="mensaje"
								name="mensaje"
								rows="4"
								placeholder="¿Qué buscas transformar en tu intimidad?"
								class="w-full px-4 py-4 border border-gray-300 rounded-none focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all duration-300 text-dark placeholder-gray-400 resize-vertical"
								required
							></textarea>
						</div>

						<!-- Experiencia Previa -->
						<div>
							<label for="experiencia" class="block text-dark font-medium mb-3 text-sm uppercase tracking-wide">
								EXPERIENCIA PREVIA EN SEXUALIDAD CONSCIENTE
							</label>
							<select 
								id="experiencia"
								name="experiencia"
								class="w-full px-4 py-4 border border-gray-300 rounded-none focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-all duration-300 text-dark"
								required
							>
								<option value="">Selecciona tu nivel</option>
								<option value="principiante">Principiante - Primera vez</option>
								<option value="intermedio">Intermedio - Algo de experiencia</option>
								<option value="avanzado">Avanzado - Experiencia significativa</option>
								<option value="experto">Experto - Practicante regular</option>
							</select>
						</div>

						<!-- Checkbox de términos -->
						<div class="flex items-start gap-3">
							<input 
								type="checkbox" 
								id="terminos"
								name="terminos"
								class="mt-1 w-4 h-4 text-accent bg-gray-100 border-gray-300 rounded focus:ring-accent"
								required
							>
							<label for="terminos" class="text-sm text-gray-600 leading-relaxed">
								* Toda la información compartida es estrictamente confidencial.
							</label>
						</div>

						<!-- Botón de envío -->
						<button 
							type="submit"
							class="w-full bg-cta hover:bg-accent text-white font-semibold py-4 px-8 transition-all duration-300 uppercase tracking-wide shadow-lg hover:shadow-xl transform hover:-translate-y-1 mt-8"
						>
							Enviar Solicitud →
						</button>

						<!-- Política de privacidad -->
						<p class="text-xs text-gray-500 text-center mt-6 leading-relaxed">
							Al registrarte, aceptas nuestra <a href="/privacidad" class="text-accent hover:underline">Política de Privacidad</a> y el uso ético de tus datos.
						</p>
					</form>
				</div>

				<!-- Imagen y Cita - Lado Derecho -->
				<div class="order-2 lg:order-2 relative h-full min-h-[80vh] overflow-hidden">
					<!-- Imagen de fondo -->
					<div class="absolute inset-0">
						<img 
							src="https://images.pexels.com/photos/29028047/pexels-photo-29028047.jpeg"
							alt="Vista panorámica de la playa en Rio Grande do Norte"
							class="w-full h-full object-cover"
						>
						<!-- Overlay gradiente -->
						<div class="absolute inset-0 bg-linear-to-t from-black/70 via-black/30 to-transparent"></div>
					</div>

					<!-- Contenido sobre la imagen -->
					<div class="absolute bottom-0 left-0 right-0 p-12 lg:p-16 text-white">
						<!-- Línea decorativa -->
						<div class="w-12 h-0.5 bg-cta mb-6"></div>

						<!-- Cita -->
						<blockquote class="font-serif text-2xl lg:text-3xl leading-relaxed mb-8 italic">
							"El placer no es un lujo, es una necesidad biológica y espiritual que merece ser honrada."
						</blockquote>

						<!-- Autor de la cita -->
						<div class="flex items-center gap-3">
							<div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center backdrop-blur-sm">
								<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20">
									<path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
								</svg>
							</div>
							<div>
								<div class="text-white font-medium text-sm uppercase tracking-wider">
									RETIROS EN BRASIL
								</div>
								<div class="text-white/80 text-sm">
									Próxima fecha • Octubre 2026
								</div>
							</div>
						</div>
					</div>
				</div>

			</div>
		</section>
	</div>
</Layout>

<script>
	import emailjs from '@emailjs/browser';

	const EMAILJS_PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;
	const EMAILJS_SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
	const EMAILJS_TEMPLATE_ID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;

	// Funcionalidad del formulario
	document.addEventListener('DOMContentLoaded', function() {
		const form = document.querySelector('form') as HTMLFormElement | null;
		
		if (form) {
			form.addEventListener('submit', async function(e) {
				e.preventDefault();

				const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
				
				if (button) {
					const originalText = button.textContent;
					const originalClasses = ['bg-cta', 'hover:bg-accent'];
					const successClasses = ['bg-green-500', 'hover:bg-green-600'];
					const errorClasses = ['bg-red-500', 'hover:bg-red-600'];

					const resetButton = () => {
						button.textContent = originalText;
						button.disabled = false;
						button.classList.remove(...successClasses, ...errorClasses);
						button.classList.add(...originalClasses);
					};

					button.textContent = 'Enviando...';
					button.disabled = true;
					button.classList.remove(...successClasses, ...errorClasses);
					button.classList.add(...originalClasses);

					if (!EMAILJS_PUBLIC_KEY || !EMAILJS_SERVICE_ID || !EMAILJS_TEMPLATE_ID) {
						button.textContent = 'Error de configuración';
						button.classList.remove(...originalClasses);
						button.classList.add(...errorClasses);

						setTimeout(() => {
							resetButton();
						}, 3500);

						return;
					}

					const formData = new FormData(form);
					const templateParams = {
						nombre: String(formData.get('nombre') || ''),
						email: String(formData.get('email') || ''),
						telefono: String(formData.get('telefono') || ''),
						mensaje: String(formData.get('mensaje') || ''),
						experiencia: String(formData.get('experiencia') || ''),
						terminos: formData.get('terminos') ? 'Sí' : 'No',
						fecha_envio: new Date().toLocaleString('es-MX')
					};

					try {
						await emailjs.send(
							EMAILJS_SERVICE_ID,
							EMAILJS_TEMPLATE_ID,
							templateParams,
							{ publicKey: EMAILJS_PUBLIC_KEY }
						);
					
						button.textContent = '¡Solicitud Enviada!';
						button.classList.remove(...originalClasses, ...errorClasses);
						button.classList.add(...successClasses);
						form.reset();

						setTimeout(() => {
							resetButton();
						}, 3000);
					} catch (error) {
						if (error && typeof error === 'object' && 'status' in error && 'text' in error) {
							const emailJsError = error as { status: number; text: string };
							console.error(`Error enviando formulario con EmailJS [${emailJsError.status}]: ${emailJsError.text}`);
						} else {
							console.error('Error enviando formulario con EmailJS:', error);
						}
						button.textContent = 'Error al enviar';
						button.classList.remove(...originalClasses, ...successClasses);
						button.classList.add(...errorClasses);
					
						setTimeout(() => {
							resetButton();
						}, 3500);
					}
				}
			});
		}
	});
</script>